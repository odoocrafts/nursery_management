<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom Portal Dashboard (Replaces default portal home for parents) -->
    <template id="nursery_portal_dashboard" name="Nursery Dashboard">
        <t t-call="portal.portal_layout">
            <t t-set="wrapwrap_classes" t-value="'o_portal_bg_dark'"/>
            <div class="container mt-4 mb-5">
                <div class="row">
                    
                    <!-- Left Column: Children & Reports -->
                    <div class="col-lg-8">
                        <!-- My Children Section -->
                        <h3 class="mb-3 text-primary">👶 My Children</h3>
                        <div class="row">
                            <t t-foreach="students" t-as="student">
                                <div class="col-md-6 mb-4">
                                    <div class="card shadow-sm border-0 h-100">
                                        <div class="card-body d-flex align-items-center">
                                            <div t-if="student.image" class="me-3">
                                                <img t-att-src="image_data_uri(student.image)" class="img rounded-circle border shadow-sm" style="width: 80px; height: 80px; object-fit: cover;"/>
                                            </div>
                                            <div>
                                                <h5 class="mb-1"><a t-attf-href="/my/students/#{student.id}" class="text-decoration-none"><span t-field="student.name"/></a></h5>
                                                <p class="mb-0 text-muted"><strong>Class:</strong> <span t-field="student.class_id"/></p>
                                                <a class="btn btn-sm btn-outline-primary mt-2 rounded-pill" t-attf-href="/my/students/#{student.id}">View Profile &amp; Chat</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                        
                        <!-- Recent Daily Reports Section -->
                        <h3 class="mt-4 mb-3 text-primary">📝 Recent Daily Reports</h3>
                        <div class="card shadow-sm border-0 mb-4">
                            <div class="list-group list-group-flush">
                                <t t-if="not reports">
                                    <div class="list-group-item text-muted p-4 text-center">No recent reports available.</div>
                                </t>
                                <t t-foreach="reports" t-as="report">
                                    <a t-attf-href="/my/reports/#{report.id}" class="list-group-item list-group-item-action p-3">
                                        <div class="d-flex w-100 justify-content-between">
                                            <h6 class="mb-1"><strong><span t-field="report.student_id"/></strong>'s Report</h6>
                                            <small><span t-field="report.date"/></small>
                                        </div>
                                        <p class="mb-1 text-muted small">
                                            Mood: <span t-field="report.mood_class"/> | Sleep: <span t-field="report.sleep_duration"/> hrs
                                        </p>
                                    </a>
                                </t>
                            </div>
                        </div>

                        <!-- Suggestions Section -->
                        <h3 class="mt-4 mb-3 text-primary">💡 Suggestions &amp; Feedback</h3>
                        <div class="card shadow-sm border-0 bg-light p-4">
                            <form action="/my/suggestion/submit" method="post">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                <div class="mb-3">
                                    <label for="subject" class="form-label fw-bold">Subject</label>
                                    <input type="text" class="form-control rounded-pill" id="subject" name="subject" placeholder="e.g. Activity idea..." required="required"/>
                                </div>
                                <div class="mb-3">
                                    <label for="suggestion" class="form-label fw-bold">Feedback Details</label>
                                    <textarea class="form-control rounded-3" id="suggestion" name="suggestion" rows="3" placeholder="I suggest..." required="required"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary rounded-pill px-4 shadow-sm">Submit Suggestion</button>
                            </form>
                            
                            <hr class="mt-4 mb-3"/>
                            <h6 class="text-muted mb-2">Previous Suggestions Status:</h6>
                            <div class="d-flex flex-wrap gap-2">
                                <t t-foreach="suggestions" t-as="sugg">
                                    <span t-attf-class="badge rounded-pill #{'bg-success' if sugg.state == 'reviewed' else 'bg-secondary'} p-2 shadow-sm">
                                        <t t-esc="sugg.name"/> (<t t-esc="dict(sugg.fields_get(allfields=['state'])['state']['selection']).get(sugg.state)"/>)
                                    </span>
                                </t>
                                <t t-if="not suggestions">
                                    <span class="text-muted small">None yet.</span>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column: Notices & Events -->
                    <div class="col-lg-4 mt-4 mt-lg-0">
                        <!-- Noticeboard -->
                        <div class="card shadow-sm border-warning border-top border-4 mb-4">
                            <div class="card-header bg-white">
                                <h4 class="mb-0 text-warning">📢 Noticeboard</h4>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush">
                                    <t t-if="not notices">
                                        <div class="list-group-item text-muted">No active notices.</div>
                                    </t>
                                    <t t-foreach="notices" t-as="notice">
                                        <div class="list-group-item p-3">
                                            <h6 class="fw-bold mb-1"><span t-field="notice.name"/></h6>
                                            <small class="text-muted d-block mb-2"><i class="fa fa-calendar me-1"/> <span t-field="notice.date"/></small>
                                            <div class="text-sm mt-1" t-raw="notice.content"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Events -->
                        <div class="card shadow-sm border-info border-top border-4">
                            <div class="card-header bg-white">
                                <h4 class="mb-0 text-info">🎈 Upcoming Events</h4>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush">
                                    <t t-if="not events">
                                        <div class="list-group-item text-muted">No planned events.</div>
                                    </t>
                                    <t t-foreach="events" t-as="ev">
                                        <div class="list-group-item p-3">
                                            <h6 class="fw-bold mb-1"><span t-field="ev.name"/></h6>
                                            <small class="text-primary fw-semibold d-block"><i class="fa fa-clock-o me-1"/> <span t-field="ev.date_start"/></small>
                                            <p class="mb-0 mt-1 small text-muted"><i class="fa fa-map-marker me-1"/> <span t-field="ev.venue"/></p>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                </div>
            </div>
        </t>
    </template>

    <!-- Student Detail (with Chatter) -->
    <template id="portal_student_detail" name="Student Details">
        <t t-call="portal.portal_layout">
            <t t-set="wrapwrap_classes" t-value="'o_portal_bg_dark'"/>
            <div class="row mt16 mb-5">
                <div class="col-lg-8 mx-auto">
                    <a href="/my" class="btn btn-sm btn-outline-secondary mb-3 rounded-pill"><i class="fa fa-arrow-left me-1"/> Back to Dashboard</a>
                    
                    <div class="card mb-4 border border-primary shadow-sm rounded">
                        <div class="card-header bg-primary text-white d-flex align-items-center">
                            <h3 class="mb-0">👶 <t t-esc="student.name"/></h3>
                        </div>
                        <div class="card-body bg-light">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <div class="d-flex align-items-center">
                                        <div t-if="student.image" class="me-4">
                                            <img t-att-src="image_data_uri(student.image)" class="img img-fluid rounded border border-secondary shadow" style="max-height: 120px; object-fit: cover;"/>
                                        </div>
                                        <div class="fs-5">
                                            <strong>🏫 Class:</strong> <span class="badge bg-info text-dark ms-1" t-field="student.class_id"/><br/>
                                            <strong>🎂 Age:</strong> <span class="ms-1" t-field="student.age"/><br/>
                                            <strong>⚧ Gender:</strong> <span class="ms-1" t-field="student.gender"/><br/>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chatter -->
                    <div id="student_chatter" class="p-4 bg-white rounded shadow-sm border border-light">
                        <h4 class="text-primary mb-3">💬 Communication History</h4>
                        <t t-call="portal.message_thread">
                            <t t-set="object" t-value="student"/>
                            <t t-set="token" t-value="student.access_token"/>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- Daily Report Detail -->
    <template id="portal_daily_report_detail" name="Daily Report">
        <t t-call="portal.portal_layout">
            <t t-set="wrapwrap_classes" t-value="'o_portal_bg_dark'"/>
            <div class="row mt16 mb-5">
                <div class="col-lg-8 mx-auto">
                    <a href="/my" class="btn btn-sm btn-outline-secondary mb-3 rounded-pill"><i class="fa fa-arrow-left me-1"/> Back to Dashboard</a>
                    
                    <div class="card shadow-sm border-0">
                        <div class="card-header bg-success text-white">
                            <h4 class="mb-0">📝 Daily Report: <span t-field="report.student_id.name"/></h4>
                            <small>Date: <span t-field="report.date"/></small>
                        </div>
                        <div class="card-body p-4">
                            <div class="row border-bottom pb-4 mb-4">
                                <div class="col-md-6 border-end">
                                    <h5 class="text-primary"><i class="fa fa-smile-o me-2"/> Well-being &amp; Mood</h5>
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-2"><strong>Class Mood:</strong> <span t-field="report.mood_class"/></li>
                                        <li class="mb-2"><strong>Play Mood:</strong> <span t-field="report.mood_play"/></li>
                                        <li class="mb-2"><strong>Sleep Duration:</strong> <span t-field="report.sleep_duration"/> hours</li>
                                        <li><strong>Settled Down well?:</strong> <span t-field="report.settled_down"/></li>
                                    </ul>
                                </div>
                                <div class="col-md-6 ps-4">
                                    <h5 class="text-primary"><i class="fa fa-cutlery me-2"/> Food &amp; Potty</h5>
                                    <ul class="list-unstyled mb-0">
                                        <li class="mb-2"><strong>Breakfast:</strong> <span t-field="report.breakfast_status"/></li>
                                        <li class="mb-2"><strong>Lunch:</strong> <span t-field="report.lunch_status"/></li>
                                        <li class="mb-2"><strong>Snacks:</strong> <span t-field="report.snack_status"/></li>
                                        <li><strong>Urine Count:</strong> <span t-field="report.urine_count"/></li>
                                    </ul>
                                </div>
                            </div>
                            
                            <div t-if="report.remarks" class="mb-4">
                                <h5 class="text-primary"><i class="fa fa-commenting-o me-2"/> Remarks &amp; Activities</h5>
                                <div class="p-3 bg-light rounded text-dark" t-raw="report.remarks"/>
                            </div>
                            
                            <div t-if="report.activity_image" class="mt-4 text-center">
                                <h5 class="text-primary text-start"><i class="fa fa-camera me-2"/> Activity Photo</h5>
                                <img t-att-src="image_data_uri(report.activity_image)" class="img-fluid rounded shadow-sm border mt-2" style="max-height: 400px;"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>
</odoo>
