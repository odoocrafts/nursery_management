<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_class_form" model="ir.ui.view">
        <field name="name">nursery.class.form</field>
        <field name="model">nursery.class</field>
        <field name="arch" type="xml">
            <form string="Class">
                <sheet>
                    <group>
                        <group string="Class Info">
                            <field name="name"/>
                            <field name="code"/>
                        </group>
                        <group string="Fees">
                            <field name="monthly_fee" widget="monetary"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Statistics">
                            <group>
                                <group string="Students &amp; Financials">
                                    <field name="student_count"/>
                                    <field name="total_due" widget="monetary"/>
                                    <field name="total_paid" widget="monetary"/>
                                </group>
                                <group string="Engagement (Recent Trend)">
                                    <field name="avg_mood_class"/>
                                    <field name="avg_mood_play"/>
                                </group>
                            </group>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nursery_class_tree" model="ir.ui.view">
        <field name="name">nursery.class.tree</field>
        <field name="model">nursery.class</field>
        <field name="arch" type="xml">
            <list string="Classes">
                <field name="name"/>
                <field name="code"/>
            </list>
        </field>
    </record>

    <record id="action_nursery_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">nursery.class</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_nursery_class" name="Classes" parent="menu_nursery_configuration_root" action="action_nursery_class" sequence="10"/>
</odoo>
