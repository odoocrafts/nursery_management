<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_suggestion_tree" model="ir.ui.view">
        <field name="name">nursery.suggestion.tree</field>
        <field name="model">nursery.suggestion</field>
        <field name="arch" type="xml">
            <list string="💡 Suggestions">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="state"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="view_nursery_suggestion_form" model="ir.ui.view">
        <field name="name">nursery.suggestion.form</field>
        <field name="model">nursery.suggestion</field>
        <field name="arch" type="xml">
            <form string="💡 Suggestion">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="draft,reviewed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"/>
                        </h1>
                    </div>
                    <group>
                        <field name="partner_id"/>
                        <field name="suggestion"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nursery_suggestion" model="ir.actions.act_window">
        <field name="name">💡 Suggestions</field>
        <field name="res_model">nursery.suggestion</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
