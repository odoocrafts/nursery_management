<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_event_tree" model="ir.ui.view">
        <field name="name">nursery.event.tree</field>
        <field name="model">nursery.event</field>
        <field name="arch" type="xml">
            <tree string="🎈 Events">
                <field name="name"/>
                <field name="date_start"/>
                <field name="date_end"/>
                <field name="venue"/>
            </tree>
        </field>
    </record>

    <record id="view_nursery_event_form" model="ir.ui.view">
        <field name="name">nursery.event.form</field>
        <field name="model">nursery.event</field>
        <field name="arch" type="xml">
            <form string="🎈 Event">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="E.g. Sports Day"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="date_start"/>
                            <field name="date_end"/>
                        </group>
                        <group>
                            <field name="venue"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Attendees">
                            <field name="attendee_ids"/>
                        </page>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_nursery_event" model="ir.actions.act_window">
        <field name="name">🎈 Events</field>
        <field name="res_model">nursery.event</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
