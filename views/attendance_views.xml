<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View -->
    <record id="view_nursery_attendance_form" model="ir.ui.view">
        <field name="name">nursery.attendance.form</field>
        <field name="model">nursery.attendance</field>
        <field name="arch" type="xml">
            <form string="Attendance">
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="class_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="status"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="notes"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree/List View -->
    <record id="view_nursery_attendance_tree" model="ir.ui.view">
        <field name="name">nursery.attendance.tree</field>
        <field name="model">nursery.attendance</field>
        <field name="arch" type="xml">
            <list string="Attendance" editable="bottom">
                <field name="date"/>
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="status" widget="badge" 
                       decoration-success="status == 'present'" 
                       decoration-danger="status == 'absent'" 
                       decoration-warning="status == 'leave'"/>
                <field name="notes"/>
            </list>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_nursery_attendance_search" model="ir.ui.view">
        <field name="name">nursery.attendance.search</field>
        <field name="model">nursery.attendance</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="date"/>
                <filter string="Present" name="state_present" domain="[('status', '=', 'present')]"/>
                <filter string="Absent" name="state_absent" domain="[('status', '=', 'absent')]"/>
                <filter string="Leave" name="state_leave" domain="[('status', '=', 'leave')]"/>
                <group expand="0" string="Group By">
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date:day'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'status'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_nursery_attendance" model="ir.actions.act_window">
        <field name="name">Attendance Records</field>
        <field name="res_model">nursery.attendance</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_group_date': 1}</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_nursery_attendance_root" 
              name="Attendance" 
              parent="menu_nursery_root" 
              sequence="20"/>

    <menuitem id="menu_nursery_attendance_records" 
              name="Attendance Records" 
              parent="menu_nursery_attendance_root" 
              action="action_nursery_attendance" 
              sequence="20"/>
</odoo>
