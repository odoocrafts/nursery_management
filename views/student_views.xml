<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_student_form" model="ir.ui.view">
        <field name="name">nursery.student.form</field>
        <field name="model">nursery.student</field>
        <field name="arch" type="xml">
            <form string="👶 Student">
                <header>
                    <button name="action_open_parent_login_wizard" type="object" string="🔑 Create Parent Login" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_reports" type="object" class="oe_stat_button" icon="fa-file-text-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="report_count"/></span>
                                <span class="o_stat_text">Reports</span>
                            </div>
                        </button>
                        <button name="action_view_attendance" type="object" class="oe_stat_button" icon="fa-calendar-check-o">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="attendance_count"/></span>
                                <span class="o_stat_text">Attendance</span>
                            </div>
                        </button>
                        <button name="action_view_fees" type="object" class="oe_stat_button" icon="fa-money">
                            <div class="o_stat_info">
                                <span class="o_stat_value"><field name="total_due"/></span>
                                <span class="o_stat_text">Due</span>
                            </div>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Student Name"/>
                        </h1>
                    </div>
                    <group>
                        <group string="🆔 Personal Details">
                            <field name="dob"/>
                            <field name="age"/>
                            <field name="gender"/>
                        </group>
                        <group string="🏫 School Details">
                            <field name="class_id"/>
                            <field name="shift"/>
                            <field name="admission_date"/>
                            <field name="parent_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_nursery_student_tree" model="ir.ui.view">
        <field name="name">nursery.student.tree</field>
        <field name="model">nursery.student</field>
        <field name="arch" type="xml">
            <list string="🎒 Students">
                <field name="name"/>
                <field name="age"/>
                <field name="gender"/>
                <field name="class_id"/>
                <field name="parent_id"/>
            </list>
        </field>
    </record>

    <record id="action_nursery_student" model="ir.actions.act_window">
        <field name="name">🎒 Students</field>
        <field name="res_model">nursery.student</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_nursery_student" name="🎒 Students" parent="menu_nursery_student_root" action="action_nursery_student" sequence="10"/>
</odoo>
