<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_daily_report_form" model="ir.ui.view">
        <field name="name">nursery.daily.report.form</field>
        <field name="model">nursery.daily.report</field>
        <field name="arch" type="xml">
            <form string="Daily Report">
                <header>
                    <!-- Add buttons here if needed -->
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="student_id" placeholder="Select Student"/>
                        </h1>
                    </div>
                    <group string="Report Details">
                        <group>
                            <field name="date"/>
                            <field name="class_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Routine &amp; Engagement">
                            <group string="Engagement &amp; Mood">
                                <group>
                                    <field name="handwashing"/>
                                    <field name="settled_down"/>
                                    <field name="engagement"/>
                                </group>
                                <group>
                                    <field name="mood_class"/>
                                    <field name="mood_play"/>
                                </group>
                            </group>
                            <group string="Physical Needs">
                                <group>
                                    <field name="sleep_duration"/>
                                    <field name="water_consumed"/>
                                    <field name="urine_count"/>
                                </group>
                            </group>
                            <group string="Food Intake">
                                <group>
                                    <field name="breakfast_status"/>
                                    <field name="lunch_status"/>
                                    <field name="snack_status"/>
                                </group>
                            </group>
                        </page>
                        <page string="Narrative &amp; Media">
                            <group>
                                <field name="remarks"/>
                                <field name="activity_image" widget="image" options="{'size': [300, 300]}"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_nursery_daily_report_tree" model="ir.ui.view">
        <field name="name">nursery.daily.report.tree</field>
        <field name="model">nursery.daily.report</field>
        <field name="arch" type="xml">
            <list string="Daily Reports">
                <field name="date"/>
                <field name="student_id"/>
                <field name="class_id"/>
                <field name="mood_class"/>
            </list>
        </field>
    </record>
    
    <record id="view_nursery_daily_report_search" model="ir.ui.view">
        <field name="name">nursery.daily.report.search</field>
        <field name="model">nursery.daily.report</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="date"/>
                <field name="class_id"/>
                <group expand="0" string="Group By">
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Class" name="group_class" context="{'group_by': 'class_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_nursery_daily_report_graph" model="ir.ui.view">
        <field name="name">nursery.daily.report.graph</field>
        <field name="model">nursery.daily.report</field>
        <field name="arch" type="xml">
            <graph string="Daily Reports" type="bar">
                <field name="class_id" type="row"/>
                <field name="date" interval="day" type="col"/>
                <field name="sleep_duration" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_nursery_daily_report" model="ir.actions.act_window">
        <field name="name">Daily Reports</field>
        <field name="res_model">nursery.daily.report</field>
        <field name="view_mode">list,form,graph</field>
    </record>

    <menuitem id="menu_nursery_daily_report" name="Daily Reports" parent="menu_nursery_daily_report_root" action="action_nursery_daily_report" sequence="10"/>
</odoo>
