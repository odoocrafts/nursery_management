<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Fee Form View -->
    <record id="view_nursery_fee_form" model="ir.ui.view">
        <field name="name">nursery.fee.form</field>
        <field name="model">nursery.fee</field>
        <field name="arch" type="xml">
            <form string="Fee Payment">
                <header>
                    <button name="action_post" string="Post" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_draft" string="Reset to Draft" type="object" invisible="state != 'posted'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="student_id"/>
                            <field name="date"/>
                            <field name="fee_type_id"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="description"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Fee Tree View -->
    <record id="view_nursery_fee_tree" model="ir.ui.view">
        <field name="name">nursery.fee.tree</field>
        <field name="model">nursery.fee</field>
        <field name="arch" type="xml">
            <list string="Fee Payments" decoration-info="state == 'draft'" decoration-muted="state == 'cancel'">
                <field name="date"/>
                <field name="student_id"/>
                <field name="fee_type_id"/>
                <field name="amount"/>
                <field name="state" widget="badge" decoration-success="state == 'posted'"/>
            </list>
        </field>
    </record>

    <!-- Fee Search View -->
    <record id="view_nursery_fee_search" model="ir.ui.view">
        <field name="name">nursery.fee.search</field>
        <field name="model">nursery.fee</field>
        <field name="arch" type="xml">
            <search>
                <field name="student_id"/>
                <field name="date"/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Posted" name="posted" domain="[('state', '=', 'posted')]"/>
                <group expand="0" string="Group By">
                    <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                    <filter string="Status" name="group_status" context="{'group_by': 'state'}"/>
                    <filter string="Date" name="group_date" context="{'group_by': 'date'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_nursery_fee" model="ir.actions.act_window">
        <field name="name">Fee Payments</field>
        <field name="res_model">nursery.fee</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Fee Type Views -->
    <record id="view_nursery_fee_type_form" model="ir.ui.view">
        <field name="name">nursery.fee.type.form</field>
        <field name="model">nursery.fee.type</field>
        <field name="arch" type="xml">
            <form string="Fee Type">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="amount"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="is_admission"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_nursery_fee_type_tree" model="ir.ui.view">
        <field name="name">nursery.fee.type.tree</field>
        <field name="model">nursery.fee.type</field>
        <field name="arch" type="xml">
            <list string="Fee Types" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="amount"/>
                <field name="is_admission"/>
            </list>
        </field>
    </record>
    
    <record id="action_nursery_fee_type" model="ir.actions.act_window">
        <field name="name">Fee Types</field>
        <field name="res_model">nursery.fee.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menus -->
    <menuitem id="menu_nursery_fee" name="Fee Management" parent="menu_nursery_root" action="action_nursery_fee" sequence="25"/>
    <menuitem id="menu_nursery_fee_type" name="Fee Types" parent="menu_nursery_configuration_root" action="action_nursery_fee_type" sequence="10"/>
</odoo>
