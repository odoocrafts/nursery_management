<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_attendance_report_wizard_form" model="ir.ui.view">
        <field name="name">nursery.attendance.report.wizard.form</field>
        <field name="model">nursery.attendance.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Class Attendance Report">
                <sheet>
                    <group>
                        <group>
                            <field name="date_from"/>
                        </group>
                        <group>
                            <field name="date_to"/>
                        </group>
                    </group>
                    <group>
                        <field name="class_ids" widget="many2many_tags" placeholder="Select classes or leave blank for all"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_print_report" string="Print Print" type="object" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="x"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_nursery_attendance_report_wizard" model="ir.actions.act_window">
        <field name="name">Class Attendance Report</field>
        <field name="res_model">nursery.attendance.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_nursery_attendance_report_wizard" 
              name="Class Attendance Report" 
              parent="menu_nursery_daily_report_root" 
              action="action_nursery_attendance_report_wizard" 
              sequence="20"/>
</odoo>
