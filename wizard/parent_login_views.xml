<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_parent_login_wizard_form" model="ir.ui.view">
        <field name="name">nursery.parent.login.wizard.form</field>
        <field name="model">nursery.parent.login.wizard</field>
        <field name="arch" type="xml">
            <form string="Create Parent Login">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        This will automatically create a Portal user for the parent or update their existing password.
                    </div>
                    <group>
                        <field name="parent_id" readonly="1"/>
                        <field name="email" widget="email"/>
                        <field name="password"/>
                    </group>
                    <group string="Copy Details to Share">
                        <field name="login_info_text" widget="CopyClipboardChar" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="Create/Update Login" type="object" name="action_create_login" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
