<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_nursery_data_import_wizard_form" model="ir.ui.view">
        <field name="name">nursery.data.import.wizard.form</field>
        <field name="model">nursery.data.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Data Import Wizard">
                <group>
                    <p class="text-muted">
                        Upload an Excel (.xlsx) or CSV (.csv) file containing the data.<br/>
                        <b>Expected Columns:</b><br/>
                        1. Student Name<br/>
                        2. Gender (Male/Female)<br/>
                        3. Date of Birth (e.g. 06-Jun-22 or YYYY-MM-DD)<br/>
                        4. Class<br/>
                        5. Parent/Guardian<br/>
                        6. Parent/Guardian/Email<br/><br/>
                        <i>Note: The wizard will automatically create the parent login using their email as the password.</i>
                    </p>
                    <field name="file" filename="file_name" widget="binary"/>
                    <field name="file_name" invisible="1"/>
                </group>
                <footer>
                    <button string="Import Data" type="object" name="action_import" class="btn-primary" data-hotkey="q"/>
                    <button string="Cancel" class="btn-secondary" special="cancel" data-hotkey="z"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_nursery_data_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Data</field>
        <field name="res_model">nursery.data.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
