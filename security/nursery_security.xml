<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Category -->
        <record id="module_category_nursery" model="ir.module.category">
            <field name="name">Nursery Management</field>
            <field name="description">Helps you manage your nursery.</field>
            <field name="sequence">10</field>
        </record>

        <!-- Groups -->
        <record id="group_nursery_teacher" model="res.groups">
            <field name="name">Nursery Teacher</field>
            <field name="category_id" ref="module_category_nursery"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_nursery_admin" model="res.groups">
            <field name="name">Nursery Admin</field>
            <field name="category_id" ref="module_category_nursery"/>
            <field name="implied_ids" eval="[(4, ref('group_nursery_teacher'))]"/>
            <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

        <!-- Record Rules for Teacher -->
        <record id="rule_nursery_class_teacher" model="ir.rule">
            <field name="name">Teacher: own class</field>
            <field name="model_id" ref="model_nursery_class"/>
            <field name="domain_force">[('teacher_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_nursery_student_teacher" model="ir.rule">
            <field name="name">Teacher: own students</field>
            <field name="model_id" ref="model_nursery_student"/>
            <field name="domain_force">[('class_id.teacher_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_nursery_attendance_teacher" model="ir.rule">
            <field name="name">Teacher: own class attendance</field>
            <field name="model_id" ref="model_nursery_attendance"/>
            <field name="domain_force">[('class_id.teacher_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_nursery_checkin_teacher" model="ir.rule">
            <field name="name">Teacher: own class check-in</field>
            <field name="model_id" ref="model_nursery_checkin"/>
            <field name="domain_force">[('student_id.class_id.teacher_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <record id="rule_nursery_daily_report_teacher" model="ir.rule">
            <field name="name">Teacher: own class daily reports</field>
            <field name="model_id" ref="model_nursery_daily_report"/>
            <field name="domain_force">[('class_id.teacher_id','=',user.id)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_teacher'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Record Rules for Admin (to override Teacher's restrictive domains) -->
        <record id="rule_nursery_class_admin" model="ir.rule">
            <field name="name">Admin: all classes</field>
            <field name="model_id" ref="model_nursery_class"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_nursery_student_admin" model="ir.rule">
            <field name="name">Admin: all students</field>
            <field name="model_id" ref="model_nursery_student"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_nursery_attendance_admin" model="ir.rule">
            <field name="name">Admin: all attendance</field>
            <field name="model_id" ref="model_nursery_attendance"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_nursery_checkin_admin" model="ir.rule">
            <field name="name">Admin: all check-in</field>
            <field name="model_id" ref="model_nursery_checkin"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <record id="rule_nursery_daily_report_admin" model="ir.rule">
            <field name="name">Admin: all daily reports</field>
            <field name="model_id" ref="model_nursery_daily_report"/>
            <field name="domain_force">[(1,'=',1)]</field>
            <field name="groups" eval="[(4, ref('group_nursery_admin'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="1"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="1"/>
        </record>

        <!-- Portal User sees only their own children -->
        <record id="rule_student_portal_user" model="ir.rule">
            <field name="name">Portal Parents: own children only</field>
            <field name="model_id" ref="model_nursery_student"/>
            <field name="domain_force">[('parent_id','=',user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User sees only their own suggestions -->
        <record id="rule_suggestion_portal_user" model="ir.rule">
            <field name="name">Portal Parents: own suggestions</field>
            <field name="model_id" ref="model_nursery_suggestion"/>
            <field name="domain_force">[('partner_id','=',user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="1"/>
            <field name="perm_unlink" eval="0"/>
        </record>

        <!-- Portal User sees only reports of their children -->
        <record id="rule_daily_report_portal_user" model="ir.rule">
            <field name="name">Portal Parents: own children reports</field>
            <field name="model_id" ref="model_nursery_daily_report"/>
            <field name="domain_force">[('student_id.parent_id','=',user.partner_id.id)]</field>
            <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
            <field name="perm_read" eval="1"/>
            <field name="perm_write" eval="0"/>
            <field name="perm_create" eval="0"/>
            <field name="perm_unlink" eval="0"/>
        </record>
    </data>
</odoo>
